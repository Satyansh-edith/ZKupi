// Prisma Schema for ZK-UPI Backend
// Using SQLite for zero-config hackathon setup

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Wallet ────────────────────────────────────────────────────────────────
// Stores ZK commitments (hashed secrets) instead of real identities.
// The actual secret/identity is NEVER stored — only the hash commitment.
model Wallet {
  id            String   @id @default(cuid())
  commitment    String   @unique // SHA-256(secret) — the ZK identity
  nullifierHash String? // Used to prevent double-spend during proof
  balance       Float    @default(10000) // Default ₹10,000 for demo
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sentTransactions     Transaction[] @relation("Sender")
  receivedTransactions Transaction[] @relation("Receiver")

  @@map("wallets")
}

// ─── Transaction ───────────────────────────────────────────────────────────
// Every payment is recorded with its ZK proof.
// No real bank account or phone number is ever stored.
model Transaction {
  id                 String   @id @default(cuid())
  senderCommitment   String // Sender's ZK identity
  receiverCommitment String? // Receiver's ZK identity (optional)
  merchantId         String? // Merchant ID (if paying merchant)
  amount             Float // Payment amount in ₹
  zkProof            String // The ZK proof submitted
  nullifier          String   @unique // Unique nullifier (prevents double-spend)
  status             String   @default("PENDING") // PENDING | VERIFIED | COMPLETED | FAILED
  isPrivate          Boolean  @default(true) // Whether identity is hidden
  timestamp          DateTime @default(now())

  // Relations
  sender   Wallet  @relation("Sender", fields: [senderCommitment], references: [commitment])
  receiver Wallet? @relation("Receiver", fields: [receiverCommitment], references: [commitment])

  @@map("transactions")
}

// ─── Nullifier ─────────────────────────────────────────────────────────────
// Stores used nullifiers to prevent double-spending.
// Core anti-fraud mechanism in ZK systems.
model Nullifier {
  id     String   @id @default(cuid())
  hash   String   @unique // SHA-256(secret + merchantId + amount + nonce)
  usedAt DateTime @default(now())
  txId   String? // Reference to the transaction that used this nullifier

  @@map("nullifiers")
}

// ─── Merchant ──────────────────────────────────────────────────────────────
model Merchant {
  id         String   @id @default(cuid())
  name       String
  merchantId String   @unique // Public merchant identifier (e.g. "shop@upi")
  balance    Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("merchants")
}
